{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/login",
            "dest": "/api/login.php"
        },
        {
            "src": "/dashboard",
            "dest": "/api/dashboard.php"
        },
        {
            "src": "/profiles",
            "dest": "/api/profiles.php"
        },
        {
            "src": "/search",
            "dest": "/api/search.php"
        },
        {
            "src": "/",
            "dest": "/api/index.php"
        }
    ]
}