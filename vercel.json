{
    "functions": {
        "*.php": {
            "runtime": "vercel-php@0.6.0"
        }
    },
    "routes": [
        {
            "src": "/login",
            "dest": "/login.php"
        },
        {
            "src": "/dashboard",
            "dest": "/dashboard.php"
        },
        {
            "src": "/profiles",
            "dest": "/profiles.php"
        },
        {
            "src": "/search",
            "dest": "/search.php"
        },
        {
            "src": "/logout",
            "dest": "/logout.php"
        },
        {
            "src": "/",
            "dest": "/login.php"
        }
    ]
}